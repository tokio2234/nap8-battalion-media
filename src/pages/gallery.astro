---
/**
 * Gallery: masonry grid of every post's cover photo, filterable by
 * category and year (client-side show/hide). Clicking a photo opens
 * its post.
 */
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORIES, CATEGORY_SLUGS } from '../config/site';
import { getPosts, postUrl, postYear, postYears, formatDate } from '../lib/posts';

const posts = await getPosts();
const years = postYears(posts);
---

<BaseLayout title="Gallery" description="Photographs from events, the school, and cultural life at the 8th NAP Battalion, Naltoqa.">
  <div class="border-b border-line">
    <div class="mx-auto max-w-6xl px-5 pb-10 pt-14">
      <h1 class="font-serif text-4xl sm:text-5xl">Gallery</h1>
      <p class="mt-3 max-w-xl text-paper/70">
        Photographs from across battalion life. Select any image to read its story.
      </p>

      <!-- Filter bar -->
      <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-4">
        <div role="group" aria-label="Filter by category" class="flex flex-wrap gap-2">
          <button
            type="button"
            data-filter-category=""
            aria-pressed="true"
            class="gallery-filter border border-line px-4 py-1.5 text-xs uppercase tracking-[0.15em] text-paper/75 transition-colors hover:border-accent-bright hover:text-accent-bright aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-paper"
          >
            All
          </button>
          {
            CATEGORY_SLUGS.map((slug) => (
              <button
                type="button"
                data-filter-category={slug}
                aria-pressed="false"
                class="gallery-filter border border-line px-4 py-1.5 text-xs uppercase tracking-[0.15em] text-paper/75 transition-colors hover:border-accent-bright hover:text-accent-bright aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-paper"
              >
                {CATEGORIES[slug].name}
              </button>
            ))
          }
        </div>

        <label class="flex items-center gap-3 text-sm text-muted">
          <span class="text-[0.7rem] uppercase tracking-[0.15em]">Year</span>
          <select
            id="gallery-year"
            class="cursor-pointer border border-line bg-panel px-3 py-2 text-paper focus:border-accent-bright"
          >
            <option value="">All years</option>
            {years.map((year) => <option value={String(year)}>{year}</option>)}
          </select>
        </label>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-5 py-14">
    <div id="gallery-grid" class="columns-1 gap-4 sm:columns-2 lg:columns-3">
      {
        posts.map((post) => (
          <a
            href={postUrl(post)}
            class="group relative mb-4 block break-inside-avoid overflow-hidden bg-panel"
            data-category={post.data.category}
            data-year={String(postYear(post))}
          >
            <Picture
              src={post.data.cover_photo}
              alt={post.data.cover_alt}
              formats={['webp']}
              fallbackFormat="jpg"
              widths={[480, 800]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              loading="lazy"
              class="w-full motion-safe:transition-transform motion-safe:duration-700 group-hover:scale-[1.04]"
            />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/90 to-transparent p-4 pt-10">
              <p class="font-serif text-lg leading-snug">{post.data.title}</p>
              <p class="mt-1 text-[0.7rem] uppercase tracking-[0.15em] text-paper/60">
                {CATEGORIES[post.data.category].name} · {formatDate(post.data.date)}
              </p>
            </div>
          </a>
        ))
      }
    </div>
    <p id="gallery-empty" class="hidden py-10 text-muted">No photos match this filter yet.</p>
  </div>

  <script>
    // Client-side filtering: show/hide grid items by category + year.
    const buttons = [...document.querySelectorAll<HTMLButtonElement>('.gallery-filter')];
    const yearSelect = document.getElementById('gallery-year') as HTMLSelectElement | null;
    const items = [...document.querySelectorAll<HTMLAnchorElement>('#gallery-grid > a')];
    const emptyNote = document.getElementById('gallery-empty');

    let activeCategory = '';

    function applyFilter() {
      const activeYear = yearSelect?.value ?? '';
      let visible = 0;
      for (const item of items) {
        const show =
          (!activeCategory || item.dataset.category === activeCategory) &&
          (!activeYear || item.dataset.year === activeYear);
        item.classList.toggle('hidden', !show);
        if (show) visible++;
      }
      emptyNote?.classList.toggle('hidden', visible > 0);
    }

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        activeCategory = button.dataset.filterCategory ?? '';
        buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === button)));
        applyFilter();
      });
    });
    yearSelect?.addEventListener('change', applyFilter);
  </script>
</BaseLayout>
