---
/**
 * About page: battalion history, commanding officer, contact, and an
 * embedded map. All prose is placeholder — replace with the real history.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';

const { lat, lng, zoom } = SITE.map;
// OpenStreetMap embed — free, no API key. The bbox is a small window around the pin.
const d = 0.02;
const mapSrc = `https://www.openstreetmap.org/export/embed.html?bbox=${lng - d}%2C${lat - d}%2C${lng + d}%2C${lat + d}&layer=mapnik&marker=${lat}%2C${lng}`;
const mapLink = `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lng}#map=${zoom}/${lat}/${lng}`;
---

<BaseLayout title="About" description={`History, leadership, and contact details of the ${SITE.title}.`}>
  <div class="border-b border-line">
    <div class="mx-auto max-w-6xl px-5 pb-10 pt-14">
      <h1 class="font-serif text-4xl sm:text-5xl">About the Battalion</h1>
      <p class="mt-3 max-w-xl text-paper/70">{SITE.title}</p>
    </div>
  </div>

  <div class="mx-auto max-w-3xl space-y-16 px-5 py-16">
    <section data-reveal>
      <h2 class="font-serif text-2xl sm:text-3xl">History</h2>
      <div class="story mt-6">
        <p>
          The 8th Battalion of the Nagaland Armed Police is stationed at Naltoqa. This is
          placeholder text — replace it with the battalion’s real history: when it was raised,
          the districts it has served, and the responsibilities it carries today.
        </p>
        <p>
          Alongside its duties, the battalion is part of the life of the surrounding villages —
          through its school, its festivals, and its community programmes. This site gathers
          those stories in one place.
        </p>
      </div>
    </section>

    <section data-reveal>
      <h2 class="font-serif text-2xl sm:text-3xl">Commanding Officer</h2>
      <div class="mt-6 border-l-2 border-accent pl-5">
        <p class="font-serif text-xl">[Name of Commandant]</p>
        <p class="mt-1 text-sm text-muted">Commandant, {SITE.shortTitle}</p>
        <p class="mt-3 text-sm leading-relaxed text-paper/70">
          Placeholder — add a short introduction of the commanding officer here.
        </p>
      </div>
    </section>

    <section data-reveal>
      <h2 class="font-serif text-2xl sm:text-3xl">Contact</h2>
      <ul class="mt-6 space-y-2 text-paper/80">
        <li>
          Email:
          <a href={`mailto:${SITE.contactEmail}`} class="text-accent-bright hover:underline">
            {SITE.contactEmail}
          </a>
        </li>
        <li>Location: {SITE.location}</li>
      </ul>
    </section>

    <section data-reveal>
      <h2 class="font-serif text-2xl sm:text-3xl">Where we are</h2>
      <div class="mt-6 border border-line">
        <iframe
          src={mapSrc}
          title={`Map showing the location of ${SITE.shortTitle}, ${SITE.location}`}
          class="aspect-video w-full"
          loading="lazy"
        ></iframe>
      </div>
      <p class="mt-3 text-sm">
        <a href={mapLink} class="text-accent-bright hover:underline" rel="noopener">
          View larger map &rarr;
        </a>
      </p>
    </section>
  </div>
</BaseLayout>
