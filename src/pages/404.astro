---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-5 py-32">
    <p class="text-[0.7rem] uppercase tracking-[0.3em] text-accent-bright">404</p>
    <h1 class="font-serif text-4xl sm:text-5xl">This page doesn’t exist.</h1>
    <a href="/" class="text-sm text-accent-bright hover:underline">Back to the front page &rarr;</a>
  </div>
</BaseLayout>
