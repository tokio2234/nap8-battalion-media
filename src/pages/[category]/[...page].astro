---
/**
 * Category listing pages: /events/, /school/, /culture/
 * Paginated at 12 posts per page (/events/2/, /events/3/, ...).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryHeader from '../../components/CategoryHeader.astro';
import PostCard from '../../components/PostCard.astro';
import Pagination from '../../components/Pagination.astro';
import { CATEGORIES, CATEGORY_SLUGS, type CategorySlug } from '../../config/site';
import { getPosts, postYears, type Post } from '../../lib/posts';
import type { Page } from 'astro';

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const paths = [];
  for (const category of CATEGORY_SLUGS) {
    const posts = await getPosts(category);
    paths.push(...paginate(posts, { params: { category }, pageSize: 12 }));
  }
  return paths;
}

const { page } = Astro.props as { page: Page<Post> };
const category = Astro.params.category as CategorySlug;
const meta = CATEGORIES[category];

// Years across the whole category (not just this page) for the filter dropdown.
const years = postYears(await getPosts(category));
---

<BaseLayout title={meta.name} description={meta.description}>
  <CategoryHeader category={category} years={years} />

  <div class="mx-auto max-w-6xl px-5 py-14">
    {
      page.data.length > 0 ? (
        <div class="grid gap-x-6 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
          {page.data.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="py-10 text-muted">No posts yet — the first one is coming soon.</p>
      )
    }
    <Pagination page={page} />
  </div>
</BaseLayout>
