---
/**
 * Individual post page: /[category]/[year]/[slug]/
 *  - full-width cover hero with title/date/location overlaid at the bottom
 *  - story in a comfortable ~700px reading column
 *  - photo gallery with lightbox
 *  - tags + "More from [Category]" (3 related posts)
 */
import { Picture, getImage } from 'astro:assets';
import { render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { CATEGORIES, type CategorySlug } from '../../../config/site';
import { getPosts, excerpt, formatDate, postYear, type Post } from '../../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: {
      category: post.data.category,
      year: String(postYear(post)),
      slug: post.id,
    },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Post };
const { title, date, location, cover_photo, cover_alt, gallery, tags } = post.data;
const category = post.data.category as CategorySlug;
const { Content } = await render(post);

// Full-size WebP variants for the lightbox links.
const galleryFull = await Promise.all(
  gallery.map((item) => getImage({ src: item.image, width: 1800, format: 'webp' }))
);

const related = (await getPosts(category)).filter((p) => p.id !== post.id).slice(0, 3);
---

<BaseLayout title={title} description={excerpt(post)}>
  <!-- Cover hero -->
  <section class="relative flex min-h-[420px] items-end overflow-hidden md:h-[68vh]">
    <Picture
      src={cover_photo}
      alt={cover_alt}
      formats={['webp']}
      fallbackFormat="jpg"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-ink/20" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto w-full max-w-6xl px-5 pb-12 pt-40">
      <p class="text-[0.7rem] uppercase tracking-[0.3em] text-accent-bright">
        {CATEGORIES[category].name}
      </p>
      <h1 class="mt-4 max-w-3xl font-serif text-4xl leading-[1.12] sm:text-5xl">{title}</h1>
      <p class="mt-4 flex flex-wrap items-center gap-x-2 text-sm text-paper/70">
        <span>{formatDate(date)}</span>
        {
          location && (
            <>
              <span aria-hidden="true">·</span>
              <span class="inline-flex items-center gap-1.5">
                <svg
                  class="h-3.5 w-3.5 text-accent-bright"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
                {location}
              </span>
            </>
          )
        }
      </p>
    </div>
  </section>

  <!-- Story -->
  <div class="mx-auto max-w-[700px] px-5 py-14">
    <div class="story">
      <Content />
    </div>
  </div>

  <!-- Gallery -->
  <section class="mx-auto max-w-6xl px-5 pb-6" aria-label="Photo gallery">
    <div class="grid grid-cols-2 gap-3 md:grid-cols-3">
      {
        gallery.map((item, index) => (
          <a
            href={galleryFull[index].src}
            data-lightbox
            data-alt={item.alt}
            class="group block overflow-hidden bg-panel"
            aria-label={`View photo: ${item.alt}`}
          >
            <Picture
              src={item.image}
              alt={item.alt}
              formats={['webp']}
              fallbackFormat="jpg"
              widths={[400, 700, 1000]}
              sizes="(min-width: 768px) 33vw, 50vw"
              loading="lazy"
              class="aspect-[4/3] w-full object-cover motion-safe:transition-transform motion-safe:duration-700 group-hover:scale-[1.05]"
            />
          </a>
        ))
      }
    </div>
  </section>

  <!-- Tags -->
  {
    tags.length > 0 && (
      <div class="mx-auto flex max-w-6xl flex-wrap gap-2 px-5 py-10">
        {tags.map((tag) => (
          <span class="border border-line px-3 py-1 text-xs uppercase tracking-[0.12em] text-muted">
            {tag}
          </span>
        ))}
      </div>
    )
  }

  <!-- Related posts -->
  {
    related.length > 0 && (
      <section class="border-t border-line" aria-label={`More from ${CATEGORIES[category].name}`}>
        <div class="mx-auto max-w-6xl px-5 py-16">
          <div class="mb-10 flex items-baseline justify-between gap-4">
            <h2 class="font-serif text-2xl sm:text-3xl">More from {CATEGORIES[category].name}</h2>
            <a href={`/${category}/`} class="text-sm text-accent-bright hover:underline">
              View all &rarr;
            </a>
          </div>
          <div class="grid gap-x-6 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((p) => (
              <PostCard post={p} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <script>
    import '../../../scripts/lightbox.js';
  </script>
</BaseLayout>
