---
/**
 * Header block for category pages: category name, one-line description,
 * and a year-filter dropdown that navigates to /[category]/[year]/.
 */
import { CATEGORIES, type CategorySlug } from '../config/site';

interface Props {
  category: CategorySlug;
  years: number[];
  selectedYear?: number;
}
const { category, years, selectedYear } = Astro.props;
const meta = CATEGORIES[category];
---

<div class="border-b border-line">
  <div class="mx-auto flex max-w-6xl flex-wrap items-end justify-between gap-6 px-5 pb-10 pt-14">
    <div>
      <h1 class="font-serif text-4xl sm:text-5xl">{meta.name}</h1>
      <p class="mt-3 max-w-xl text-paper/70">{meta.description}</p>
    </div>
    {
      years.length > 0 && (
        <label class="flex items-center gap-3 text-sm text-muted">
          <span class="uppercase tracking-[0.15em] text-[0.7rem]">Year</span>
          <select
            data-year-filter
            data-base={`/${category}/`}
            class="cursor-pointer border border-line bg-panel px-3 py-2 text-paper focus:border-accent-bright"
          >
            <option value="">All years</option>
            {years.map((year) => (
              <option value={String(year)} selected={selectedYear === year}>
                {year}
              </option>
            ))}
          </select>
        </label>
      )
    }
  </div>
</div>

{
  meta.intro && (
    <div class="mx-auto max-w-6xl px-5 pt-10">
      <p class="max-w-3xl border-l-2 border-accent pl-5 text-[0.95rem] leading-relaxed text-paper/75">
        {meta.intro}
      </p>
    </div>
  )
}

<script>
  // Year dropdown: navigate to the year archive (or back to the full listing).
  document.querySelectorAll<HTMLSelectElement>('select[data-year-filter]').forEach((select) => {
    select.addEventListener('change', () => {
      const base = select.dataset.base ?? '/';
      window.location.href = select.value ? `${base}${select.value}/` : base;
    });
  });
</script>
